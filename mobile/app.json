{
  "expo": {
    "name": "EnglishMitraAI",
    "slug": "englishmitra-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7B61FF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.englishmitraai",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "We need microphone access to practice your English pronunciation.",
        "NSSpeechRecognitionUsageDescription": "We use speech recognition to help improve your pronunciation.",
        "NSCameraUsageDescription": "Camera access for profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#7B61FF"
      },
      "package": "com.englishmitraai",
      "permissions": [
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/notification-icon.png",
          "color": "#7B61FF"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow EnglishMitraAI to access your microphone for pronunciation practice."
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow EnglishMitraAI to access your microphone for pronunciation practice.",
          "speechRecognitionPermission": "Allow EnglishMitraAI to recognize your speech."
        }
      ],
      "expo-secure-store",
      "./plugins/withAndroidBuildFixes"
    ],
    "scheme": "englishmitraai",
    "extra": {
      "eas": {
        "projectId": "6d776523-27d0-4864-a799-000401dc819e"
      }
    }
  }
}

# ============================================================
# EnglishMitraAi - Environment Variables (100% FREE STACK)
# Copy this to .env and fill in your values
# ============================================================

# Supabase Configuration (Free Tier)
# Get from: https://supabase.com/dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Groq API (FREE — 14,400 requests/day free tier)
# Get from: https://console.groq.com → API Keys → Create API Key
EXPO_PUBLIC_GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# ============================================================
# NO PAID APIS USED IN THIS PROJECT
# ✅ Groq (free) — replaces OpenAI GPT-4
# ✅ expo-speech (free) — replaces ElevenLabs TTS
# ✅ react-native-voice (free) — replaces Whisper STT
# ✅ google-translate-api-x (free) — replaces DeepL
# ✅ Supabase free tier — database + auth + storage
